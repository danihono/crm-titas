# Copie para .env.local e preencha com a config do seu Web App (Firebase console
# > Configurações do projeto > Seus apps > SDK do Firebase). Esses valores são
# PÚBLICOS por design — a segurança vem das Security Rules + App Check.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App Check (reCAPTCHA v3) — site key pública. Em dev use o debug token.
VITE_RECAPTCHA_SITE_KEY=

# Liga os emuladores locais no dev (true/false). Deixe true para desenvolver
# sem tocar em produção; false para apontar para o projeto Firebase real.
VITE_USE_EMULATORS=true

# Região das Cloud Functions (callable askTitaIA)
VITE_FUNCTIONS_REGION=southamerica-east1
