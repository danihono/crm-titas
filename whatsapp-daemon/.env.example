# whatsapp-daemon — variáveis de ambiente (exemplo). NÃO commitar valores reais.

# Porta HTTP (Cloud Run injeta automaticamente). Local: 8080.
PORT=8080

# Projeto GCP. Em Cloud Run vem de GOOGLE_CLOUD_PROJECT; local pode fixar aqui.
FIREBASE_PROJECT_ID=titas-c8967

# Região (só informativo/log).
WA_REGION=southamerica-east1

# Concorrência da rehidratação no boot (evita thundering-herd de handshakes).
WA_REHYDRATE_CONCURRENCY=3

# Retenção padrão em dias para novas conexões (0 = guardar para sempre).
WA_DEFAULT_RETENTION_DAYS=0

# Janela (ms) pós-conexão em que o sync inicial pode preencher o buraco de mensagens
# do período desconectado (gap-fill). Default: 5 minutos.
WA_GAP_FILL_WINDOW_MS=300000

# Origem permitida no CORS (a URL do frontend). Aceita lista separada por vírgula.
# Sem definir, o daemon responde '*' (qualquer origem) e loga um aviso no boot —
# em produção, defina sempre. Ex.: https://titas-c8967.web.app
# WA_ALLOWED_ORIGIN=https://titas-c8967.web.app

# Níveis de log. WA_BAILEYS_LOG_LEVEL deve ficar em 'warn'+ para NUNCA logar
# conteúdo de mensagem nem chaves (Baileys loga isso em debug/trace).
WA_LOG_LEVEL=info
WA_BAILEYS_LOG_LEVEL=warn

# --- Desenvolvimento local com emuladores do Firebase ---
# Descomente para apontar o Admin SDK aos emuladores (sem credenciais reais):
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# --- Produção fora do Cloud Run (ex.: rodar localmente contra o projeto real) ---
# Caminho para a chave da service account (Application Default Credentials):
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
