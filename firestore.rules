rules_version = '2';

// Single-tenant + SUPER TITAN: cada usuário acessa o seu próprio users/{uid}/...,
// e os DONOS DO SISTEMA (allowlist de e-mail) leem todos os tenants (somente leitura).
// A allowlist abaixo deve espelhar src/lib/owners.ts (OWNER_EMAILS).
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function owner(uid) { return signedIn() && request.auth.uid == uid; }
    function isSuperOwner() {
      return signedIn() && request.auth.token.email in [
        'danielboy200627@gmail.com'
        // , 'dono2@exemplo.com'
        // , 'dono3@exemplo.com'
      ];
    }

    match /users/{uid} {
      allow read: if owner(uid) || isSuperOwner();
      allow write: if owner(uid);

      match /{document=**} {
        allow read: if owner(uid) || isSuperOwner();
        allow write: if owner(uid);
      }
    }

    // Leituras agregadas (collectionGroup) para os dashboards SUPER TITAN — só donos.
    match /{path=**}/deals/{id}      { allow read: if isSuperOwner(); }
    match /{path=**}/invoices/{id}   { allow read: if isSuperOwner(); }
    match /{path=**}/contacts/{id}   { allow read: if isSuperOwner(); }
    match /{path=**}/activities/{id} { allow read: if isSuperOwner(); }

    // Status da conexão de WhatsApp (QR + estado). Cliente LÊ o próprio; NUNCA escreve
    // (quem escreve é o daemon via Admin SDK). Coleção top-level de propósito, para o
    // read-only ser limpo — regras do Firestore são UNIÃO permissiva, então um write:false
    // aninhado sob users/{uid}/{document=**} não revogaria o owner-write recursivo.
    match /whatsappStatus/{uid} {
      allow read: if owner(uid) || isSuperOwner();
      allow write: if false;
    }
    // NOTA: as credenciais/chaves do Signal ficam em whatsappSessions/** — deliberadamente
    // SEM nenhuma regra aqui, então caem no default-deny abaixo (só o Admin SDK acessa).

    // Nega tudo o que não casar acima.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
