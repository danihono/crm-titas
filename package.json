{
  "name": "titas-crm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "emulators": "firebase emulators:start --only auth,firestore,storage --import=./.emulator-data --export-on-exit=./.emulator-data",
    "emulators:all": "firebase emulators:start --import=./.emulator-data --export-on-exit=./.emulator-data",
    "dev:full": "concurrently -k -n EMU,VITE -c magenta,cyan \"npm:emulators\" \"npm:dev\"",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "firebase": "^11.1.0",
    "framer-motion": "^12.42.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.1.0",
    "firebase-admin": "^13.0.2",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
